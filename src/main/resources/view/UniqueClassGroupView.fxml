<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:id="root" styleClass="pane-with-white-border">
    <VBox alignment="CENTER_LEFT" minHeight="80" spacing="4" styleClass="card-alt">
        <padding>
            <Insets top="5" right="5" bottom="5" left="15" />
        </padding>
        <Label fx:id="classGroupName" styleClass="view_cell_big_label" />
        <Label fx:id="numContacts" styleClass="view_cell_small_label" />
    </VBox>
    <StackPane fx:id="contactListPlaceholder" VBox.vgrow="ALWAYS" />
</VBox>
