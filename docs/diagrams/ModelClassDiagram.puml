@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyAddressBook" as ReadOnlyAddressBook
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class AddressBook
Class ModelManager
Class UserPrefs

Class UniqueContactList
Class Contact
Class UniqueAssignmentList
Class Assignment
Class UniqueContactAssignmentList
Class ContactAssignment
Class UniqueClassGroupList
Class ClassGroup

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

AddressBook .up.|> ReadOnlyAddressBook

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyAddressBook
ModelManager -left-> "1" AddressBook
ModelManager --> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

AddressBook *-down-> "1" UniqueContactList
AddressBook *-down-> "1" UniqueAssignmentList
AddressBook *-down-> "1" UniqueContactAssignmentList
AddressBook *-down-> "1" UniqueClassGroupList

UniqueContactList -down-> "~* all" Contact
UniqueAssignmentList --> "~* all" Assignment
UniqueContactAssignmentList --> "~* all" ContactAssignment
UniqueClassGroupList --> "~* all" ClassGroup

Contact -[hidden]up--> I
UniqueContactList -[hidden]right-> I

ModelManager --> "~* filtered" Contact
ModelManager -down-> "~* filtered" Assignment
ModelManager -down-> "~* filtered" ClassGroup

@enduml
